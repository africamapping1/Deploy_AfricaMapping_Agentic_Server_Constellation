{
  "identity": {
    "name": "africamapping-basic",
    "title": "AfricaMapping Basic Viewer",
    "tenant": "africamapping",
    "version": "v1",
    "status": "active"
  },
  "map": {
    "center": [9.0225, 38.7470],
    "zoom": 16,
    "maxZoom": 22,
    "mode": "2d"
  },
  "basemap": {
    "name": "osm",
    "provider": "OpenStreetMap"
  },
  "projection": {
    "coordinateSystem": "EPSG:4326",
    "transformation": null
  },
  "layers": [
    {
      "name": "buildings",
      "type": "geojson",
      "source": "../prototypes/first-leaflet-viewer/africamapping-first-polygon.geojson",
      "visible": true,
      "popupFields": ["id", "tenant", "layer", "status"]
    }
  ],
  "widgets": {
    "layerToggle": true,
    "scaleBar": false,
    "coordinateReadout": false
  },
  "interaction": {
    "selectionEnabled": true,
    "popupFields": ["id", "tenant", "layer", "status"]
  },
  "styling": {
    "theme": "default"
  }
}
