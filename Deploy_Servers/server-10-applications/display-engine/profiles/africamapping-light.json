{
  "identity": {
    "name": "africamapping-light",
    "title": "AfricaMapping Light View",
    "tenant": "africamapping",
    "version": "v1",
    "status": "active"
  },
  "map": {
    "center": [9.0225, 38.7470],
    "zoom": 15,
    "maxZoom": 22,
    "mode": "2d"
  },
  "basemap": {
    "name": "carto-light",
    "provider": "CARTO"
  },
  "projection": {
    "coordinateSystem": "EPSG:4326",
    "transformation": null
  },
  "layers": [
    {
      "name": "water",
      "type": "geojson",
      "source": "./water.geojson",
      "visible": true,
      "opacity": 0.7,
      "popupFields": ["id", "layer", "status"],
      "style": {
        "color": "#1d4ed8",
        "weight": 2,
        "fillColor": "#60a5fa",
        "fillOpacity": 0.5
      }
    },
    {
      "name": "landcover",
      "type": "geojson",
      "source": "./landcover.geojson",
      "visible": true,
      "opacity": 0.5,
      "popupFields": ["id", "layer", "status"],
      "style": {
        "color": "#15803d",
        "weight": 2,
        "fillColor": "#4ade80",
        "fillOpacity": 0.35
      }
    },
    {
      "name": "buildings",
      "type": "geojson",
      "source": "./africamapping-first-polygon.geojson",
      "visible": true,
      "opacity": 1,
      "popupFields": ["id", "tenant", "layer", "status"],
      "style": {
        "color": "#b91c1c",
        "weight": 2,
        "fillColor": "#fca5a5",
        "fillOpacity": 0.45
      }
    }
  ],
  "widgets": {
    "layerToggle": true,
    "scaleBar": true,
    "coordinateReadout": true
  },
  "interaction": {
    "selectionEnabled": true,
    "popupFields": ["id", "layer", "status"]
  },
  "styling": {
    "theme": "light"
  }
}
